{
  "name": "pmharden",
  "version": "0.1.0",
  "description": "Security hardening CLI for npm, pnpm, yarn, and bun — config linter, global package auditor, and .npmrc secret scanner",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "pmharden": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "lint": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "npm",
    "pnpm",
    "yarn",
    "bun",
    "security",
    "supply-chain",
    "hardening",
    "audit",
    "cli"
  ],
  "author": "nadimtuhin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nadimtuhin/pmharden"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.0.0",
    "typescript": "^5.4.0"
  }
}
